{
  "name": "ts-backups",
  "type": "module",
  "version": "0.1.3",
  "description": "A simple TypeScript starter kit using Bun.",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-backups#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-backups.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-backups/issues"
  },
  "keywords": [
    "typescript",
    "database",
    "backups",
    "bun",
    "package"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "backup": "./dist/bin/cli.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts && bun run compile",
    "compile": "bun build ./bin/cli.ts --compile --minify --outfile bin/backup",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64",
    "compile:linux-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-x64 --outfile bin/backup-linux-x64",
    "compile:linux-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-arm64 --outfile bin/backup-linux-arm64",
    "compile:windows-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-windows-x64 --outfile bin/backup-windows-x64.exe",
    "compile:darwin-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-x64 --outfile bin/backup-darwin-x64",
    "compile:darwin-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-arm64 --outfile bin/backup-darwin-arm64",
    "zip": "bun run zip:all",
    "zip:all": "bun run zip:linux-x64 && bun run zip:linux-arm64 && bun run zip:windows-x64 && bun run zip:darwin-x64 && bun run zip:darwin-arm64",
    "zip:linux-x64": "zip -j bin/backup-linux-x64.zip bin/backup-linux-x64",
    "zip:linux-arm64": "zip -j bin/backup-linux-arm64.zip bin/backup-linux-arm64",
    "zip:windows-x64": "zip -j bin/backup-windows-x64.zip bin/backup-windows-x64.exe",
    "zip:darwin-x64": "zip -j bin/backup-darwin-x64.zip bin/backup-darwin-x64",
    "zip:darwin-arm64": "zip -j bin/backup-darwin-arm64.zip bin/backup-darwin-arm64",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build && bun run compile:all && bun run zip",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bunx --bun bumpx prompt --recursive",
    "release:patch": "bunx --bun bumpx patch --recursive --yes",
    "release:minor": "bunx --bun bumpx minor --recursive --yes",
    "release:major": "bunx --bun bumpx major --recursive --yes",
    "postinstall": "bunx git-hooks",
    "dev:docs": "bun --bun bunpress dev docs",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "devDependencies": {
    "@stacksjs/clapp": "^0.2.0",
    "better-dx": "^0.2.15"
  },
  "git-hooks": {
    "pre-commit": {
      "staged-lint": {
        "**/*.{js,ts}": "bunx --bun pickier --fix",
        "**/*.{json,yaml,yml,md}": "bunx --bun pickier --fix"
      }
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
